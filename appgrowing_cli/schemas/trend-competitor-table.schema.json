{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Trend Competitor Table",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "ok",
    "data_source",
    "keywords",
    "this_period",
    "last_period",
    "selection_rules",
    "query_options",
    "meta",
    "competitors",
    "generated_at"
  ],
  "properties": {
    "ok": { "type": "boolean" },
    "data_source": { "type": "string", "const": "api" },
    "keywords": {
      "type": "array",
      "items": { "type": "string" }
    },
    "this_period": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end", "label"],
      "properties": {
        "start": { "type": "string" },
        "end": { "type": "string" },
        "label": { "type": "string" }
      }
    },
    "last_period": {
      "type": "object",
      "additionalProperties": false,
      "required": ["start", "end", "label"],
      "properties": {
        "start": { "type": "string" },
        "end": { "type": "string" },
        "label": { "type": "string" }
      }
    },
    "selection_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["top_rank_limit", "min_rank_change_gt", "pick_top_n", "dedup_rule"],
      "properties": {
        "top_rank_limit": { "type": "integer" },
        "min_rank_change_gt": { "type": "integer" },
        "pick_top_n": { "type": "integer" },
        "dedup_rule": { "type": "string" }
      }
    },
    "query_options": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "market",
        "purpose",
        "dimension",
        "pages",
        "material_pages",
        "accurate_search",
        "order",
        "distribution_top_n",
        "material_top_n"
      ],
      "properties": {
        "market": {
          "type": "array",
          "items": { "type": "string" }
        },
        "purpose": { "type": "integer" },
        "dimension": { "type": "string" },
        "pages": { "type": "integer" },
        "material_pages": { "type": "integer" },
        "accurate_search": { "type": "integer" },
        "order": { "type": "string" },
        "distribution_top_n": { "type": "integer" },
        "material_top_n": { "type": "integer" }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidates_count", "final_count", "continent_map_error"],
      "properties": {
        "candidates_count": { "type": "integer" },
        "final_count": { "type": "integer" },
        "continent_map_error": { "type": ["string", "null"] }
      }
    },
    "competitors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "keyword",
          "period",
          "app_id",
          "product_name",
          "appgrowing_link",
          "system_platform",
          "current_rank",
          "previous_rank",
          "rank_change",
          "ad_count_current",
          "ad_count_previous",
          "ad_count_change_ratio",
          "material_count_current",
          "material_count_previous",
          "material_count_change_ratio",
          "material_type_distribution",
          "channel_distribution",
          "continent_distribution",
          "language_distribution_top",
          "top_video_materials",
          "top_image_materials",
          "meta"
        ],
        "additionalProperties": true,
        "properties": {
          "keyword": { "type": "string" },
          "period": { "type": "string" },
          "app_id": { "type": "string" },
          "product_name": { "type": "string" },
          "appgrowing_link": { "type": "string" },
          "system_platform": { "type": "string" },
          "current_rank": { "type": ["integer", "null"] },
          "previous_rank": { "type": ["integer", "null"] },
          "rank_change": { "type": ["integer", "null"] },
          "ad_count_current": { "type": ["integer", "null"] },
          "ad_count_previous": { "type": ["integer", "null"] },
          "ad_count_change_ratio": { "type": ["number", "null"] },
          "material_count_current": { "type": ["integer", "null"] },
          "material_count_previous": { "type": ["integer", "null"] },
          "material_count_change_ratio": { "type": ["number", "null"] },
          "material_type_distribution": { "type": "array" },
          "channel_distribution": { "type": "array" },
          "continent_distribution": { "type": "array" },
          "language_distribution_top": { "type": "array" },
          "top_video_materials": { "type": "array" },
          "top_image_materials": { "type": "array" },
          "meta": { "type": "object" }
        }
      }
    },
    "generated_at": { "type": "string" }
  }
}
