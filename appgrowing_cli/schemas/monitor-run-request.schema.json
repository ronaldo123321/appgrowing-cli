{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://appgrowing-cli.local/schemas/monitor-run-request.schema.json",
  "title": "MonitorRunRequest",
  "type": "object",
  "required": ["app", "keywords", "period", "baseline_period", "mvp_app_ids"],
  "properties": {
    "app": {
      "type": "object",
      "required": ["name", "slug"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "slug": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "keywords": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "market": {
      "type": "array",
      "items": { "type": "string", "minLength": 2 }
    },
    "period": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "string", "format": "date" },
        "end": { "type": "string", "format": "date" }
      },
      "additionalProperties": false
    },
    "baseline_period": {
      "type": "object",
      "required": ["start", "end"],
      "properties": {
        "start": { "type": "string", "format": "date" },
        "end": { "type": "string", "format": "date" }
      },
      "additionalProperties": false
    },
    "mvp_app_ids": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "material_id_by_keyword": {
      "type": "object",
      "additionalProperties": { "type": "string", "minLength": 1 }
    },
    "filters": {
      "type": "object",
      "properties": {
        "top_n": { "type": "integer", "minimum": 1, "default": 15 },
        "min_rank_change": { "type": "integer", "minimum": 1, "default": 3 },
        "pages": { "type": "integer", "minimum": 1, "default": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
